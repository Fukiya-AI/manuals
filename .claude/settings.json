{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push)",
      "Bash(git pull)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(pip install*)",
      "Bash(python*)",
      "Bash(streamlit run*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(del /f*)",
      "Bash(rmdir /s*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(curl*)",
      "Bash(wget*)"
    ]
  }
}
