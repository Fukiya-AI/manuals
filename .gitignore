*.xlsx
*.xls
*.csv
*.numbers
!サンプル*.xlsx
!サンプル*.xls
!サンプル*.csv

# Python自動生成ファイル
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/
env/

# OS・エディタの自動生成ファイル
.DS_Store
Thumbs.db
desktop.ini
*.swp

# ログ・一時ファイル
*.log
*.tmp
*.temp
